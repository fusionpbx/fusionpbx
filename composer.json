{
    "name": "fusionpbx/fusionpbx",
    "description": "FusionPBX with Laravel Eloquent ORM for easier database management",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "illuminate/database": "^10.0",
        "illuminate/events": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "FusionPBX\\Models\\": "app/models/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
