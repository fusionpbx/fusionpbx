# FusionPBX Laravel 12 Configuration
APP_NAME="FusionPBX"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://fusionpbx.local

# Database Configuration
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fusionpbx
DB_USERNAME=fusionpbx
DB_PASSWORD=

# FreeSWITCH ESL Configuration
ESL_HOST=127.0.0.1
ESL_PORT=8021
ESL_PASSWORD=ClueCon

# WebRTC Configuration
WEBRTC_ENABLED=true
WEBRTC_WSS_URL=wss://fusionpbx.local:7443
SIP_DOMAIN=fusionpbx.local
SIP_WS_PORT=5066

# Cache & Session
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Laravel Reverb (WebSocket Server)
REVERB_APP_ID=fusionpbx
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# Broadcast Configuration
BROADCAST_DRIVER=reverb
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# CDR Configuration
CDR_LIVE_ENABLED=true
CDR_RETENTION_DAYS=90

# Lua Scripts
LUA_SCRIPTS_PATH=/usr/share/freeswitch/scripts

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@fusionpbx.local"
MAIL_FROM_NAME="${APP_NAME}"

# Logging
LOG_CHANNEL=daily
LOG_LEVEL=info

# Security
SANCTUM_STATEFUL_DOMAINS=fusionpbx.local
SESSION_DOMAIN=fusionpbx.local
